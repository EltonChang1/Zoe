# Zoe — mobile client configuration.
# Copy this file to `.env` (or set in your shell / Expo secrets) before
# running `npm start`. Only variables prefixed with EXPO_PUBLIC_ are
# exposed to the JavaScript bundle.

# Base URL of the Zoe backend (see `server/README.md`).
#   - iOS simulator: http://localhost:4000 works out of the box
#   - Android emulator: use http://10.0.2.2:4000
#   - Physical device on the same Wi-Fi: use your machine's LAN IP
#     (e.g. http://192.168.1.42:4000)
# If unset, the client auto-detects the Metro host, which is usually what
# you want for `expo start`.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Google account sign-in. At minimum set a web client ID for Expo AuthSession;
# native client IDs can be added when building signed iOS / Android apps.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
