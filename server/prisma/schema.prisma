// Zoe backend schema.
// Source of truth for all columns / relations is PRD/Zoe_Content_Model_Sample_Data_Pack.md.
// tsvector columns are added in the accompanying SQL migration — Prisma only
// knows about them as `Unsupported("tsvector")`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ObjectType {
  place
  restaurant
  cafe
  bar
  perfume
  album
  fashion
  sneaker
  product
}

enum PostType {
  photo
  carousel
  short_video
}

enum DetailLayout {
  discovery_photo
  album_review
  product_hero
}

enum ListVisibility {
  public
  followers
  private
}

enum RankMovement {
  up
  down
  new
  stable
}

enum ReportSubjectType {
  user
  post
  short
  comment
  short_comment
}

enum ReportReason {
  spam
  harassment
  hate
  sexual
  violence
  self_harm
  misinformation
  ip_violation
  other
}

enum ReportStatus {
  open
  reviewed
  actioned
  dismissed
}

// -------- Auth -----------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  handle       String   @unique
  displayName  String
  passwordHash String
  avatarUrl    String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// When set, the address is considered verified (login allowed as normal).
  emailVerifiedAt                 DateTime?
  emailVerificationTokenHash      String? @unique
  emailVerificationExpiresAt      DateTime?
  passwordResetTokenHash          String? @unique
  passwordResetExpiresAt          DateTime?
  /// Throttle POST /auth/resend-verification (authenticated).
  lastVerificationEmailSentAt     DateTime?

  sessions      Session[]
  posts         Post[]
  lists         RankingList[]
  comments      Comment[]
  likes         Like[]
  saves         Save[]
  shorts        Short[]
  shortLikes    ShortLike[]
  shortSaves    ShortSave[]
  shortComments ShortComment[]
  followers     Follow[]       @relation("follower")
  following     Follow[]       @relation("followee")

  // Moderation. Blocks hide content in BOTH directions (neither user sees
  // the other anywhere in the app). `blocksMade` is "users I have
  // blocked"; `blockedBy` is "users who have blocked me".
  blocksMade     Block[]  @relation("blocker")
  blockedBy      Block[]  @relation("blocked")
  reportsMade    Report[] @relation("reporter")
  pushTokens     PushToken[]

  @@map("users")
}

model Session {
  id         String   @id @default(cuid())
  // sha256(token || pepper) — raw token lives only with the client.
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userAgent  String?
  ipAddress  String?

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// -------- Catalog --------------------------------------------------------

model Object {
  id              String     @id @default(cuid())
  type            ObjectType
  title           String
  subtitle        String?
  city            String?
  neighborhood    String?
  tags            String[]
  shortDescriptor String?
  heroImage       String?
  metadata        Json?
  createdAt       DateTime   @default(now())

  // Generated tsvector column (see prisma/migrations/**/search.sql).
  searchTsv       Unsupported("tsvector")? @map("search_tsv")

  posts           Post[]
  entries         RankingEntry[]
  shorts          Short[]

  @@index([type])
  @@index([city])
  @@map("objects")
}

// -------- Social & content ----------------------------------------------

model Post {
  id             String        @id @default(cuid())
  authorId       String
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  objectId       String
  object         Object        @relation(fields: [objectId], references: [id])

  postType       PostType      @default(photo)
  detailLayout   DetailLayout  @default(discovery_photo)

  headline       String
  caption        String
  tags           String[]

  // Denormalised ranking context shown on the card / detail.
  rankingListId  String?
  rankingList    RankingList?  @relation(fields: [rankingListId], references: [id])
  rankingRank    Int?
  rankingMovement RankMovement? @default(stable)
  rankingDelta   Int?

  locationLabel  String?
  aspect         String?       @default("tall") // tall | square | wide
  featured       Boolean       @default(false)

  publishedAt    DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  searchTsv      Unsupported("tsvector")? @map("search_tsv")

  comments       Comment[]
  likes          Like[]
  saves          Save[]

  @@index([authorId, publishedAt])
  @@index([publishedAt])
  @@index([rankingListId])
  @@map("posts")
}

model RankingList {
  id          String         @id @default(cuid())
  ownerId     String
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  category    String
  description String?
  visibility  ListVisibility @default(public)
  coverImage  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  entries     RankingEntry[]
  posts       Post[]

  @@index([ownerId])
  @@index([category])
  @@map("ranking_lists")
}

model RankingEntry {
  id        String       @id @default(cuid())
  listId    String
  list      RankingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  objectId  String
  object    Object       @relation(fields: [objectId], references: [id])
  rank      Int
  movement  RankMovement @default(stable)
  delta     Int?
  note      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([listId, objectId])
  @@unique([listId, rank])
  @@index([listId])
  @@map("ranking_entries")
}

// -------- Graph ---------------------------------------------------------

model Follow {
  followerId String
  follower   User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followeeId String
  followee   User     @relation("followee", fields: [followeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([followerId, followeeId])
  @@index([followeeId])
  @@map("follows")
}

model Like {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@index([postId])
  @@map("likes")
}

model Save {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@index([postId])
  @@map("saves")
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("replies")

  body      String
  likes     Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([postId, createdAt])
  @@index([parentId])
  @@map("comments")
}

model Short {
  id         String   @id @default(cuid())
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  objectId   String
  object     Object   @relation(fields: [objectId], references: [id])

  hookLine   String
  caption    String
  audioLabel String?
  heroImage  String
  videoUrl   String?

  rankingListTitle String?
  rankingRank      Int?
  rankingMovement  RankMovement? @default(stable)

  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  likedBy  ShortLike[]
  savedBy  ShortSave[]
  comments ShortComment[]

  @@index([authorId, publishedAt])
  @@index([publishedAt])
  @@map("shorts")
}

model ShortLike {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shortId   String
  short     Short    @relation(fields: [shortId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, shortId])
  @@index([shortId])
  @@map("short_likes")
}

model ShortSave {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shortId   String
  short     Short    @relation(fields: [shortId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, shortId])
  @@index([shortId])
  @@map("short_saves")
}

model ShortComment {
  id        String         @id @default(cuid())
  shortId   String
  short     Short          @relation(fields: [shortId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    ShortComment?  @relation("shortCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ShortComment[] @relation("shortCommentReplies")

  body      String
  likes     Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([shortId, createdAt])
  @@index([parentId])
  @@map("short_comments")
}

// -------- Moderation ----------------------------------------------------

// User-to-user block. A single row hides content symmetrically — both
// sides of the pair stop seeing each other in feeds, search, comments,
// notifications, and profile pages. Apple Guideline 1.2 requires this
// for any UGC app.
model Block {
  blockerId String
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

// User-submitted report against content or another user. Reports are
// write-only for end users; review happens out-of-band (ops tooling /
// admin). Apple Guideline 1.2 requires in-app reporting for UGC.
model Report {
  id          String            @id @default(cuid())
  reporterId  String
  reporter    User              @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  subjectType ReportSubjectType
  subjectId   String
  reason      ReportReason
  details     String?
  status      ReportStatus      @default(open)
  createdAt   DateTime          @default(now())
  resolvedAt  DateTime?

  @@index([reporterId])
  @@index([subjectType, subjectId])
  @@index([status, createdAt])
  @@map("reports")
}

// Device-level Expo push token registration. A token can move across users
// (log out/login on shared phone), so we key on `token` and upsert.
model PushToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String    @unique
  platform   String?
  appVersion String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime  @default(now())
  disabledAt DateTime?

  @@index([userId])
  @@index([disabledAt])
  @@map("push_tokens")
}
