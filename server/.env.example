# Postgres connection string used by Prisma + runtime.
DATABASE_URL="postgresql://zoe:zoe@localhost:5432/zoe?schema=public"

# Public host/port the Hono server listens on.
PORT=4000
HOST=0.0.0.0

# Trust + logging
NODE_ENV=development
LOG_LEVEL=debug

# Tokens live ~30 days; rotate if compromised.
SESSION_TTL_DAYS=30
# Optional — hashed tokens are used in DB even without this, but
# setting a pepper hardens hashes further.
SESSION_TOKEN_PEPPER=

# ---------- Uploads ----------
# `local` (default) writes to UPLOADS_DIR and serves bytes through the
# API. `s3` presigns PUT URLs against an S3-compatible bucket (AWS S3,
# Cloudflare R2, Backblaze B2, MinIO).
UPLOADS_DRIVER=local
UPLOADS_DIR=.uploads

# Base URL the sign endpoint returns for PUBLIC reads. Leave blank on
# local to auto-derive from the request origin. REQUIRED when
# UPLOADS_DRIVER=s3 — set it to your CloudFront / R2 custom domain.
# UPLOADS_PUBLIC_BASE_URL=https://media.example.com

# HMAC secret for local-driver signed PUT URLs. Generate per-env.
UPLOADS_SIGNING_SECRET=dev-signing-secret

# Size caps (bytes) — enforced server-side at sign time.
UPLOADS_IMAGE_MAX_BYTES=12582912
UPLOADS_VIDEO_MAX_BYTES=83886080
UPLOADS_SIGNED_TTL_SECONDS=600

# ---------- S3 / R2 (only used when UPLOADS_DRIVER=s3) ----------
# AWS S3 example:
#   S3_REGION=us-east-1
#   S3_BUCKET=zoe-media-prod
#   S3_ACCESS_KEY_ID=AKIA...
#   S3_SECRET_ACCESS_KEY=...
#
# Cloudflare R2 example:
#   S3_REGION=auto
#   S3_BUCKET=zoe-media
#   S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#   S3_ACCESS_KEY_ID=...
#   S3_SECRET_ACCESS_KEY=...
#   S3_FORCE_PATH_STYLE=true
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false

# ---------- Push notifications (Expo) ----------
# Keep disabled for local unless you have real device tokens.
PUSH_NOTIFICATIONS_ENABLED=false
# Optional bearer token for Expo Push API. Recommended for production.
# EXPO_PUSH_ACCESS_TOKEN=

# ---------- Transactional email (verification + password reset) ----------
# Without SMTP, development logs the message; production should set SMTP.
# MAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# Deep links in emails (Expo scheme). Default matches app.json `scheme`.
# APP_DEEPLINK_ORIGIN=zoe://
